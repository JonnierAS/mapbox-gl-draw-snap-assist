{
  "name": "@geosolution-apps/mapbox-gl-draw-snap-assist",
  "version": "0.1.0",
  "description": "Snap-to-vertex, snap-to-edge, alignment guides, and vertex deletion for @mapbox/mapbox-gl-draw",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch"
  },
  "peerDependencies": {
    "@mapbox/mapbox-gl-draw": ">=1.3.0",
    "maplibre-gl": ">=3.0.0"
  },
  "dependencies": {
    "@turf/bearing": "^7.0.0",
    "@turf/distance": "^7.0.0",
    "@turf/helpers": "^7.0.0",
    "@turf/nearest-point-on-line": "^7.0.0"
  },
  "devDependencies": {
    "@mapbox/mapbox-gl-draw": "^1.4.3",
    "maplibre-gl": "^4.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0"
  },
  "keywords": [
    "mapbox-gl-draw",
    "maplibre",
    "snap",
    "alignment",
    "guides",
    "drawing"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/geosolution-app/mapbox-gl-draw-snap-assist"
  }
}
